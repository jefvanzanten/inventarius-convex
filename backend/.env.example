# Kopieer dit bestand naar .env.local en vul de waarden in.
# NOOIT .env.local committen naar source control.

# Unieke naam voor deze Convex deployment
INSTANCE_NAME=inventarius

# Genereer met: openssl rand -hex 32
INSTANCE_SECRET=

# Backend origins (aanpassen voor productie/remote deployment)
CONVEX_CLOUD_ORIGIN=http://127.0.0.1:3210
CONVEX_SITE_ORIGIN=http://127.0.0.1:3211

# Admin key - gegenereerd NA eerste docker compose up
# Uitvoeren: docker compose exec backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_ADMIN_KEY=

# URL voor de Convex CLI (zelfde als CONVEX_CLOUD_ORIGIN)
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
